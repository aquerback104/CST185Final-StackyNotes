<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StackyNotes.Views.EditNotePage"
             Title="Edit Note Card">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label Text="✏️"
                   FontSize="36"
                   HorizontalOptions="Center" />

            <Label Text="Edit Stack Card"
                   Style="{StaticResource PageTitleLabelStyle}" />

            <Label Text="Update the selected note card or delete it from SQLite. Changes will show on the stack list when you return."
                   Style="{StaticResource BodyLabelStyle}" />

            <Border Padding="14"
                    BackgroundColor="{StaticResource CardBackgroundColor}"
                    Stroke="{StaticResource BorderColor}"
                    StrokeThickness="1">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Card Title"
                           Style="{StaticResource SectionHeaderLabelStyle}" />
                    <Entry x:Name="TitleEntry"
                           Style="{StaticResource FormEntryStyle}"
                           Placeholder="Card title" />

                    <Label Text="Card Details"
                           Style="{StaticResource SectionHeaderLabelStyle}" />
                    <Editor x:Name="ContentEditor"
                            Placeholder="Card details"
                            AutoSize="TextChanges"
                            HeightRequest="110"
                            BackgroundColor="White"
                            TextColor="Black" />

                    <Label Text="Stack Name"
                           Style="{StaticResource SectionHeaderLabelStyle}" />
                    <Entry x:Name="StackNameEntry"
                           Style="{StaticResource FormEntryStyle}"
                           Placeholder="Stack name" />

                    <HorizontalStackLayout Spacing="8">
                        <CheckBox x:Name="CompletedCheckBox" />
                        <Label Text="Mark this note as completed"
                               VerticalOptions="Center"
                               TextColor="#3A3A3A" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Button Text="Save Changes"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Clicked="OnSaveClicked" />

            <Button Text="Delete Card"
                    Style="{StaticResource DangerButtonStyle}"
                    Clicked="OnDeleteClicked" />

            <Button Text="Back to Stack List"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Clicked="OnBackClicked" />

            <Label x:Name="StatusLabel"
                   FontSize="14"
                   TextColor="{StaticResource MutedColor}"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
