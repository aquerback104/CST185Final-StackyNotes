<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="StackyNotes.Views.StackPreviewPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Preview">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="18">
            <Label Text="👀"
                   FontSize="40"
                   HorizontalOptions="Center" />

            <Label Text="Stack Preview"
                   Style="{StaticResource PageTitleLabelStyle}" />

            <Label Text="Here is the note you passed from the home page. Review it, then continue into your saved cards if it looks right."
                   Style="{StaticResource BodyLabelStyle}" />

            <Border Padding="20"
                    BackgroundColor="{StaticResource CardBackgroundColor}"
                    Stroke="{StaticResource BorderColor}"
                    StrokeThickness="1">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Previewed note"
                           Style="{StaticResource SectionHeaderLabelStyle}" />
                    <Label
                        x:Name="ReceivedNoteLabel"
                        FontSize="22"
                        FontAttributes="Bold"
                        TextColor="#2E7D32"
                        HorizontalTextAlignment="Center" />
                    <Label Text="This page makes the app flow easier to follow during testing and screenshots."
                           Style="{StaticResource CaptionLabelStyle}" />
                </VerticalStackLayout>
            </Border>

            <Button
                Text="Open My Stack List"
                Style="{StaticResource PrimaryButtonStyle}"
                Clicked="OnOpenStacksClicked" />

            <Button
                Text="Go Back"
                Style="{StaticResource SecondaryButtonStyle}"
                Clicked="OnBackClicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
